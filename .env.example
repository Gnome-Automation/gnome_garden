# GnomeGarden Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Mercury Bank API
# =============================================================================
# Get your API token from Mercury dashboard → Settings → API → Tokens
# Set MERCURY_SANDBOX=true for testing, false for production
MERCURY_API_KEY=your-mercury-api-key-here
MERCURY_SANDBOX=true
# Mercury Bank webhook secret — set this after registering your webhook endpoint
# in the Mercury dashboard (Settings → Webhooks → Add endpoint)
MERCURY_WEBHOOK_SECRET=your-mercury-webhook-secret-here

# =============================================================================
# AI Models - Z.AI (Zhipu AI)
# =============================================================================
# Required for agent LLM capabilities (GLM-4.7, GLM-5 models)
# Get your API key from: https://open.bigmodel.cn
ZAI_API_KEY=your-zai-api-key-here

# Optional, for model providers or local experiments that read Anthropic directly.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Web Search - Brave Search API
# =============================================================================
# Required for web search in agents
# Get your API key from: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key-here

# =============================================================================
# Company bootstrap facts
# =============================================================================
# Used by Company.DefaultRegistration and Company.DefaultPaymentDestinations.
GNOME_COMPANY_FEIN=your-company-fein-here
GNOME_MERCURY_CHECKING_ACCOUNT_NUMBER=your-account-number-here

# =============================================================================
# Procurement source fallbacks
# =============================================================================
# Prefer database-backed SourceCredential records for long-lived credentials.
# These env vars are local repair/bootstrap fallbacks.
SAM_GOV_API_KEY=your-sam-gov-api-key-here
PLANETBIDS_USERNAME=your-planetbids-username-here
PLANETBIDS_PASSWORD=your-planetbids-password-here
PUBLICPURCHASE_USERNAME=your-publicpurchase-username-here
PUBLICPURCHASE_PASSWORD=your-publicpurchase-password-here

# =============================================================================
# Local development sign-in override
# =============================================================================
# Dev defaults exist, but setting these makes another workstation deterministic.
GARDEN_DEV_EMAIL=dev-admin@example.com
GARDEN_DEV_PASSWORD=dev-admin-password
GARDEN_DEV_DISPLAY_NAME=Dev Admin

# =============================================================================
# Sensitive value encryption
# =============================================================================
# Optional in dev because endpoint secret_key_base can be used. Set this to keep
# encrypted company/procurement values portable across machines and releases.
GARDEN_CREDENTIAL_ENCRYPTION_KEY=generate-32-byte-base64-or-long-random-string

# =============================================================================
# Database (Production only)
# =============================================================================
# DATABASE_URL=postgres://user:password@localhost/gnome_garden_prod
# POOL_SIZE=10
# ECTO_IPV6=false

# =============================================================================
# Phoenix (Production only)
# =============================================================================
# SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
# PHX_HOST=example.com
# PHX_SERVER=true
# PORT=4000
# DNS_CLUSTER_QUERY=

# =============================================================================
# Authentication (Production only)
# =============================================================================
# TOKEN_SIGNING_SECRET=generate-with-mix-phx.gen.secret

# =============================================================================
# Pi sidecar service (Production only)
# =============================================================================
# PI_SERVICE_TOKEN=generate-a-long-random-service-token

# =============================================================================
# Acquisition document storage (Production only)
# =============================================================================
# GARAGE_ACCESS_KEY=your-garage-access-key
# GARAGE_SECRET_KEY=your-garage-secret-key
# GARAGE_BUCKET=gnome-garden-acquisition
# GARAGE_ENDPOINT_URL=https://garage.example.com
# GARAGE_REGION=garage
# GARAGE_PREFIX=acquisition/
# ALLOW_LOCAL_STORAGE_IN_PROD=false
