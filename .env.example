# GnomeGarden Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Mercury Bank API
# =============================================================================
# Get your API token from Mercury dashboard → Settings → API → Tokens
# Set MERCURY_SANDBOX=true for testing, false for production
MERCURY_API_KEY=your-mercury-api-key-here
MERCURY_SANDBOX=true
# Mercury Bank webhook secret — set this after registering your webhook endpoint
# in the Mercury dashboard (Settings → Webhooks → Add endpoint)
MERCURY_WEBHOOK_SECRET=your-mercury-webhook-secret-here

# =============================================================================
# AI Models - Z.AI (Zhipu AI)
# =============================================================================
# Required for agent LLM capabilities (GLM-4.7, GLM-5 models)
# Get your API key from: https://open.bigmodel.cn
ZAI_CODING_PLAN_API_KEY=your-zai-api-key-here

# =============================================================================
# Web Search - Brave Search API
# =============================================================================
# Required for web search in agents
# Get your API key from: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key-here

# =============================================================================
# Database (Production only)
# =============================================================================
# DATABASE_URL=postgres://user:password@localhost/gnome_garden_prod

# =============================================================================
# Phoenix (Production only)
# =============================================================================
# SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
# PHX_HOST=example.com
# PHX_SERVER=true
# PORT=4000

# =============================================================================
# Authentication (Production only)
# =============================================================================
# TOKEN_SIGNING_SECRET=generate-with-mix-phx.gen.secret
